{
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "custom": true,
            "customGradient": true,
            "gradients": [
                {
                    "name": "Degradado Delirium",
                    "gradient": "linear-gradient(90deg, #4AD2BE 0%, #F08B57 50%, #F7E59D 100%)",
                    "slug": "delirium-gradient"
                },
                {
                    "name": "Brillo Turquesa",
                    "gradient": "radial-gradient(circle, rgba(74,210,190,0.15) 0%, rgba(13,13,13,0) 70%)",
                    "slug": "turquoise-glow"
                }
            ],
            "palette": [
                {
                    "name": "Fondo Oscuro",
                    "slug": "background",
                    "color": "#0D0D0D"
                },
                {
                    "name": "Texto Blanco",
                    "slug": "contrast",
                    "color": "#FFFFFF"
                },
                {
                    "name": "Turquesa Primario",
                    "slug": "primary",
                    "color": "#4AD2BE"
                },
                {
                    "name": "Naranja Secundario",
                    "slug": "secondary",
                    "color": "#F08B57"
                },
                {
                    "name": "Crema Terciario",
                    "slug": "tertiary",
                    "color": "#F7E59D"
                },
                {
                    "name": "Gris Carbón (Tarjetas)",
                    "slug": "charcoal",
                    "color": "#1A1A1A"
                },
                {
                    "name": "Texto Muted",
                    "slug": "muted",
                    "color": "#A0A0A0"
                }
            ]
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        },
        "spacing": {
            "units": ["px", "em", "rem", "vh", "vw", "%"]
        },
        "typography": {
            "customFontSize": true,
            "fontSizes": [
                {
                    "size": "0.875rem",
                    "slug": "small",
                    "name": "Pequeño"
                },
                {
                    "size": "1rem",
                    "slug": "medium",
                    "name": "Normal"
                },
                {
                    "size": "1.25rem",
                    "slug": "large",
                    "name": "Grande"
                },
                {
                    "size": "1.75rem",
                    "slug": "x-large",
                    "name": "Muy Grande"
                },
                {
                    "size": "2.5rem",
                    "slug": "xx-large",
                    "name": "Gigante"
                }
            ],
            "fontFamilies": [
                {
                    "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Open Sans\", \"Helvetica Neue\", sans-serif",
                    "slug": "system",
                    "name": "Sistema (Moderno)"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--system)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                "typography": {
                    "textDecoration": "none"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--secondary)"
                    }
                }
            },
            "button": {
                "color": {
                    "text": "var(--wp--preset--color--background)",
                    "background": "var(--wp--preset--color--primary)"
                },
                "typography": {
                    "fontWeight": "600",
                    "textDecoration": "none"
                },
                "border": {
                    "radius": "8px"
                },
                "spacing": {
                    "padding": {
                        "top": "0.75rem",
                        "bottom": "0.75rem",
                        "left": "1.5rem",
                        "right": "1.5rem"
                    }
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--secondary)"
                    }
                }
            },
            "heading": {
                "typography": {
                    "fontWeight": "700",
                    "fontFamily": "var(--wp--preset--font-family--system)"
                }
            }
        }
    }
}
